# ─────────────────────────────────────────────────────────────────────────────
# Alumni Influencers Platform — Environment Variables
# Copy this file to '.env' and fill in the values before running the server.
# ─────────────────────────────────────────────────────────────────────────────

# Server
# The port the Express server will listen on
PORT=3000

# Database
# MongoDB connection string — local instance or Atlas cloud URI
# Example (local):  mongodb://localhost:27017/alumni_influencers_db
# Example (Atlas):  mongodb+srv://<user>:<pass>@cluster.mongodb.net/alumni_influencers?retryWrites=true
MONGODB_URI=mongodb://localhost:27017/alumni_influencers_db

# JWT Authentication
# Secret key used to sign and verify JSON Web Tokens — use a long, random string in production
JWT_SECRET=your_super_secret_jwt_key_change_in_production
# How long a JWT token remains valid (e.g. 30d = 30 days, 24h = 24 hours)
JWT_EXPIRE=30d

# Email (SMTP)
# Used for: email verification, password reset, and bid winner notifications
# For local development, use https://ethereal.email to get test credentials
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=ethereal_user
EMAIL_PASS=ethereal_pass
# The sender address shown in outgoing emails
EMAIL_FROM=noreply@eastminster.ac.uk

# Client URL (used for CORS and constructing email links)
CLIENT_URL=http://localhost:3000

# Admin Bootstrap Secret
# Used by POST /api/admin/promote to promote a registered user to admin role.
# Set this to a strong, random value. Remove or disable this route after first use.
ADMIN_SECRET=change_this_to_a_strong_secret

